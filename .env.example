# ============================================================
# Pilot Hub — Environment Variables
# Copy this file to .env.local and fill in all values.
# Never commit .env.local to version control.
# ============================================================

# --- Database ---
# PostgreSQL connection string
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/pilot_hub"

# --- Auth ---
# Generate with: openssl rand -base64 32
AUTH_SECRET="your-auth-secret-here"
# Full URL of your app (no trailing slash)
AUTH_URL="http://localhost:3000"
# NEXTAUTH_URL is an alias used by some NextAuth internals
NEXTAUTH_URL="http://localhost:3000"

# --- Email (Resend) ---
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"
# Verified sender address in Resend
RESEND_FROM_EMAIL="noreply@yourdomain.com"
RESEND_FROM_NAME="Pilot Hub"

# --- App ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Displayed as the vendor/company name throughout the portal
NEXT_PUBLIC_COMPANY_NAME="Your Company Name"
# URL to your company logo (optional — falls back to text)
NEXT_PUBLIC_COMPANY_LOGO_URL=""

# --- File Storage (Vercel Blob — optional for logo uploads) ---
# BLOB_READ_WRITE_TOKEN=""

# --- Cron ---
# Secret used to protect cron job endpoints from unauthorized calls
CRON_SECRET="your-cron-secret-here"

# --- Future: SSO (Phase 3) ---
# SAML_CERT=""
# SAML_ENTRY_POINT=""
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""
